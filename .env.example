# JEE Smart Suite | Environment Template
# Copy this file to backend/.env and frontend/.env (if needed)

# --- AI & LMM CONFIG ---
# Get your key at console.groq.com
GROQ_API_KEY=your_groq_key_here

# Get your key at aistudio.google.com
GEMMA_API_KEY=your_gemini_key_here

# --- DISCOVERY ENGINE ---
# Get your key at tavily.com
TAVILY_API_KEY=your_tavily_key_here

# --- VIDEO ASSETS ---
# Get your key at console.cloud.google.com (YouTube Data API v3)
YOUTUBE_API_KEY=your_youtube_key_here

# --- DATABASE (SUPABASE) ---
# Get these from your Supabase Project Settings > API
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# --- DATABASE (PINECONE - Optional for Vector Search) ---
PINECONE_API_KEY=your_pinecone_key
PINECONE_ENV=your_pinecone_env
